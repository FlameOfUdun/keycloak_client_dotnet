{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Keycloak": {
    "Server": "https://id.example.com",
    "Realm": "myrealm",
    "Resource": "myapp",
    "Credentials": {
      "Secret": "REPLACE_ME"
    },
    "Authentication": {
      "ValidateAudience": false,
      "RolesSource": "RealmAndResource"
    },
    "Authorization": {
      "CacheDuration": null
    }
  }
}
